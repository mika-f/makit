{
  "name": "@natsuneko-laboratory/makit",
  "version": "0.3.0",
  "description": "Generate static documentation sites from Markdown, powered by Next.js.",
  "license": "MIT",
  "repository": "https://github.com/mika-f/makit.git",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "makit": "./dist/cli/index.mjs"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./adapter": {
      "types": "./dist/adapter.d.mts",
      "import": "./dist/adapter.mjs"
    },
    "./metadata": {
      "types": "./dist/metadata.d.mts",
      "import": "./dist/metadata.mjs"
    }
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "prepublishOnly": "pnpm run build",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@natsuneko-laboratory/makit-runtime": "workspace:*",
    "@tailwindcss/postcss": "^4.3.2",
    "@tailwindcss/typography": "^0.5.20",
    "chokidar": "^5.0.0",
    "citty": "^0.2.2",
    "es-module-lexer": "^1.7.0",
    "fast-glob": "^3.3.3",
    "gray-matter": "^4.0.3",
    "hast-util-to-string": "^3.0.1",
    "jiti": "^2.7.0",
    "lucide-react": "^0.468.0",
    "next": "^16.2.10",
    "pagefind": "^1.5.2",
    "picocolors": "^1.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "rehype-raw": "^7.0.0",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "shiki": "^4.3.1",
    "sirv": "^3.0.2",
    "tailwindcss": "^4.3.2",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.0.0",
    "vfile": "^6.0.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/hast": "^3.0.5",
    "@types/node": "^26.1.1",
    "tsdown": "^0.22.8",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}