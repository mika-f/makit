{
  "name": "makit",
  "version": "0.1.0",
  "description": "Generate static documentation sites from Markdown, powered by Next.js.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "makit": "./dist/cli/index.mjs"
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "citty": "^0.2.2",
    "jiti": "^2.7.0",
    "zod": "^4.4.3",
    "gray-matter": "^4.0.3",
    "unified": "^11.0.5",
    "remark-parse": "^11.0.0",
    "remark-gfm": "^4.0.1",
    "remark-rehype": "^11.1.2",
    "rehype-stringify": "^10.0.1",
    "rehype-raw": "^7.0.0",
    "rehype-slug": "^6.0.0",
    "hast-util-to-string": "^3.0.1",
    "unist-util-visit": "^5.0.0",
    "shiki": "^4.3.1",
    "chokidar": "^5.0.0",
    "sirv": "^3.0.2",
    "picocolors": "^1.1.1",
    "fast-glob": "^3.3.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsdown": "^0.22.8",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
